generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                                             String                   @id @default(uuid())
  createdAt                                      DateTime                 @default(now())
  updatedAt                                      DateTime                 @updatedAt
  accountStatus                                  AccountStatus            @default(PENDING_SETUP)
  ageAtSignup                                    Int?
  birthMonth                                     Int?
  birthYear                                      Int?
  contentTier                                    ContentTier?
  coppaConsentAt                                 DateTime?
  coppaConsentGranted                            Boolean?
  coppaConsentRequired                           Boolean                  @default(false)
  isTestNumber                                   Boolean                  @default(false)
  locale                                         String                   @default("en")
  marketingOptIn                                 Boolean                  @default(false)
  onboardingCompletedAt                          DateTime?
  otpRetryCount                                  Int                      @default(0)
  otpSendOn                                      DateTime?
  parentEmail                                    String?
  phone                                          String                   @unique
  privacyAcceptedAt                              DateTime?
  role                                           UserRole                 @default(TEEN)
  termsAcceptedAt                                DateTime?
  timezone                                       String?
  onboardingStep                                 Int                      @default(0)
  fcmToken                                       String?
  chatSessions                                   ChatSession[]
  CommunityActivityLog                           CommunityActivityLog[]
  CommunityBookmark                              CommunityBookmark[]
  CommunityPost                                  CommunityPost[]
  CommunityReply                                 CommunityReply[]
  consentRequests                                ConsentRequest[]
  cycleLogs                                      CycleLog[]
  cycleProfile                                   CycleProfile?
  cycleRecords                                   CycleRecord[]
  escalations                                    EscalationEvent[]
  expertChats                                    ExpertChatSession[]      @relation("ExpertSessions")
  expertSessions                                 ExpertChatSession[]      @relation("UserSessions")
  ModerationLog                                  ModerationLog[]
  notificationHistory                            NotificationHistory[]
  NotificationPreferences                        NotificationPreferences?
  PeerLineSession_PeerLineSession_menteeIdToUser PeerLineSession[]        @relation("PeerLineSession_menteeIdToUser")
  PeerLineSession_PeerLineSession_mentorIdToUser PeerLineSession[]        @relation("PeerLineSession_mentorIdToUser")
  personalization                                PersonalizationProfile?
  PostReaction                                   PostReaction[]
  profile                                        Profile?
  reflections                                    Reflection[]
  subscription                                   Subscription?
  avatar                                         UserAvatar?
  userBadges                                     UserBadge[]
  progress                                       UserProgress[]
  userQuests                                     UserQuest[]
}

model Profile {
  id                String   @id @default(uuid())
  userId            String   @unique
  displayName       String
  pronouns          String?
  journeyName       String?
  totalPoints       Int      @default(0)
  bloomLevel        Int      @default(1)
  mentorStatus      String   @default("none")
  certifiedTopicIds String[] @default([])
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PersonalizationProfile {
  id                 String    @id @default(uuid())
  userId             String    @unique
  goals              String[]
  periodComfortScore Int?
  periodStatus       String    @default("waiting")
  periodContentTone  String    @default("moderate")
  interestTopics     String[]
  contentWeights     Json      @default("{}")
  quizCompletedAt    DateTime?
  lastUpdatedAt      DateTime  @default(now()) @updatedAt
  user               User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model UserAvatar {
  id                  String   @id @default(uuid())
  userId              String   @unique
  bodyTypeId          Int      @default(1)
  skinToneId          Int      @default(1)
  hairStyleId         Int      @default(1)
  hairColorId         Int      @default(1)
  eyeShapeId          Int      @default(1)
  eyeColorId          Int      @default(1)
  outfitId            Int      @default(1)
  accessories         Int[]    @default([])
  unlockedOutfits     Int[]    @default([1])
  unlockedAccessories Int[]    @default([])
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ConsentRequest {
  id            String               @id @default(uuid())
  userId        String
  parentEmail   String
  token         String               @unique
  status        ConsentRequestStatus @default(PENDING)
  sentAt        DateTime             @default(now())
  approvedAt    DateTime?
  approvedIp    String?
  expiresAt     DateTime
  reminder1Sent Boolean              @default(false)
  reminder2Sent Boolean              @default(false)
  user          User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model CycleProfile {
  id                       String      @id @default(uuid())
  userId                   String      @unique
  trackerMode              TrackerMode @default(watching_waiting)
  lastPeriodStart          DateTime?
  lastPeriodEnd            DateTime?
  avgCycleLength           Float?
  setupCompletedAt         DateTime?
  createdAt                DateTime    @default(now())
  updatedAt                DateTime    @updatedAt
  avgPeriodDuration        Float?
  coefficientOfVar         Float?
  confidenceLevel          String      @default("none")
  currentCycleDay          Int?
  currentLogStreak         Int         @default(0)
  currentPhase             String      @default("waiting")
  federatedLearningConsent Boolean     @default(false)
  lastLogDate              DateTime?
  longestLogStreak         Int         @default(0)
  patternCache             Json?
  predictedNextEnd         DateTime?
  predictedNextStart       DateTime?
  predictionWindowEarly    DateTime?
  predictionWindowLate     DateTime?
  showFertilityWindow      Boolean     @default(false)
  stdCycleLength           Float?
  user                     User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model CycleLog {
  id             String   @id @default(uuid())
  userId         String
  date           DateTime
  flow           String?
  symptoms       String[]
  createdAt      DateTime @default(now())
  activityTags   String[]
  crampIntensity Int?
  energyLevel    Int?
  hasVoiceNote   Boolean  @default(false)
  isRetroactive  Boolean  @default(false)
  moodPrimary    String?
  moodSecondary  String[]
  noteCiphertext String?
  noteIv         String?
  nutritionTags  String[]
  sleepHours     Float?
  sleepQuality   Int?
  updatedAt      DateTime @updatedAt
  user           User     @relation(fields: [userId], references: [id])

  @@unique([userId, date])
  @@index([userId, date])
}

model CycleRecord {
  id                  String    @id @default(uuid())
  userId              String
  cycleNumber         Int
  startDate           DateTime
  endDate             DateTime?
  periodStartDate     DateTime
  periodEndDate       DateTime?
  cycleLengthDays     Int?
  periodDurationDays  Int?
  isComplete          Boolean   @default(false)
  avgCrampIntensity   Float?
  mostCommonSymptoms  String[]
  predictedStartDate  DateTime?
  predictionErrorDays Int?
  createdAt           DateTime  @default(now())
  user                User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, cycleNumber])
}

model LearningJourney {
  id             String      @id @default(uuid())
  title          String
  description    String
  ageBand        String?
  topics         String[]    @default([])
  goals          String[]    @default([])
  tags           String[]    @default([])
  contentTone    String      @default("moderate")
  minContentTier ContentTier @default(TEEN_EARLY)
  bannerImage    String?
  category       String?
  createdAt      DateTime    @default(now())
  isActive       Boolean     @default(true)
  slug           String      @unique @default(uuid())
  thumbnailUrl   String?
  totalXP        Int         @default(0)
  updatedAt      DateTime    @updatedAt
  episodes       Episode[]
}

model Episode {
  id           String          @id @default(uuid())
  journeyId    String
  order        Int             @default(0)
  title        String
  content      Json            @default("[]")
  points       Int             @default(50)
  createdAt    DateTime        @default(now())
  description  String?
  isActive     Boolean         @default(true)
  slug         String          @unique @default(uuid())
  updatedAt    DateTime        @updatedAt
  journey      LearningJourney @relation(fields: [journeyId], references: [id], onDelete: Cascade)
  reflections  Reflection[]
  userProgress UserProgress[]
}

model UserProgress {
  id               String   @id @default(uuid())
  userId           String
  episodeId        String
  completed        Boolean  @default(false)
  updatedAt        DateTime @updatedAt
  completedItems   Json     @default("[]")
  lastViewedItemId String?
  history          Json?
  episode          Episode  @relation(fields: [episodeId], references: [id], onDelete: Cascade)
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, episodeId])
}

model Reflection {
  id        String   @id @default(uuid())
  userId    String
  episodeId String
  content   String?
  voiceUrl  String?
  isPrivate Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  episode   Episode  @relation(fields: [episodeId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([episodeId])
}

model Quest {
  id          String      @id @default(uuid())
  title       String
  description String
  type        String
  points      Int
  userQuests  UserQuest[]
}

model UserQuest {
  id          String   @id @default(uuid())
  userId      String
  questId     String
  completedAt DateTime @default(now())
  quest       Quest    @relation(fields: [questId], references: [id])
  user        User     @relation(fields: [userId], references: [id])
}

model Badge {
  id          String      @id @default(uuid())
  name        String
  description String
  iconUrl     String
  userBadges  UserBadge[]
}

model UserBadge {
  id        String   @id @default(uuid())
  userId    String
  badgeId   String
  awardedAt DateTime @default(now())
  badge     Badge    @relation(fields: [badgeId], references: [id])
  user      User     @relation(fields: [userId], references: [id])
}

model Subscription {
  id        String    @id @default(uuid())
  userId    String    @unique
  tier      String
  status    String
  expiresAt DateTime?
  user      User      @relation(fields: [userId], references: [id])
}

model NotificationPreferences {
  id                String   @id @default(uuid())
  userId            String   @unique
  periodPrediction  Boolean  @default(true)
  dailyReminder     Boolean  @default(true)
  dailyReminderTime String   @default("20:00")
  symptomPatterns   Boolean  @default(true)
  latePeriod        Boolean  @default(true)
  streakAtRisk      Boolean  @default(true)
  monthlyInsights   Boolean  @default(false)
  phaseChange       Boolean  @default(false)
  doctorConnect     Boolean  @default(true)
  cycleMilestones   Boolean  @default(true)
  globalEnabled     Boolean  @default(true)
  updatedAt         DateTime @updatedAt
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model NotificationHistory {
  id       String    @id @default(uuid())
  userId   String
  type     String
  title    String
  body     String
  deepLink String?
  payload  Json?     @default("{}")
  sentAt   DateTime  @default(now())
  openedAt DateTime?
  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, type])
  @@index([sentAt])
}

model ExpertChatSession {
  id        String              @id @default(uuid())
  userId    String
  expertId  String
  status    String              @default("active")
  lastMsgAt DateTime            @default(now())
  createdAt DateTime            @default(now())
  updatedAt DateTime            @updatedAt
  messages  ExpertChatMessage[]
  expert    User                @relation("ExpertSessions", fields: [expertId], references: [id], onDelete: Cascade)
  user      User                @relation("UserSessions", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expertId])
}

model ExpertChatMessage {
  id        String            @id @default(uuid())
  sessionId String
  senderId  String
  content   String
  createdAt DateTime          @default(now())
  isRead    Boolean           @default(false)
  session   ExpertChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
}

model ChatSession {
  id               String          @id @default(uuid())
  userId           String
  title            String?
  isActive         Boolean         @default(true)
  maxDistressLevel EscalationLevel @default(LEVEL_0)
  lastMsgAt        DateTime        @default(now())
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  messages         ChatMessage[]
  user             User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model ChatMessage {
  id        String      @id @default(uuid())
  sessionId String
  sender    ChatSender
  content   String
  metadata  Json?
  createdAt DateTime    @default(now())
  session   ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
}

model EscalationEvent {
  id         String          @id @default(uuid())
  userId     String
  sessionId  String?
  level      EscalationLevel
  reason     String
  resolvedAt DateTime?
  resolvedBy String?
  createdAt  DateTime        @default(now())
  user       User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model CommunityActivityLog {
  id              String          @id
  userId          String
  circleId        String
  lastVisitedAt   DateTime        @default(now())
  CommunityCircle CommunityCircle @relation(fields: [circleId], references: [id])
  User            User            @relation(fields: [userId], references: [id])

  @@unique([userId, circleId])
  @@index([userId, circleId])
}

model CommunityBookmark {
  id             String          @id
  userId         String
  postId         String?
  createdAt      DateTime        @default(now())
  replyId        String?
  CommunityPost  CommunityPost?  @relation(fields: [postId], references: [id])
  CommunityReply CommunityReply? @relation(fields: [replyId], references: [id])
  User           User            @relation(fields: [userId], references: [id])

  @@unique([userId, postId])
  @@unique([userId, replyId])
  @@index([userId, postId])
  @@index([userId, replyId])
}

model CommunityCircle {
  id                   String                 @id
  slug                 String                 @unique
  name                 String
  description          String?
  iconEmoji            String?
  accentColor          String?
  minContentTier       ContentTier?
  maxContentTier       ContentTier?
  requiresPreReview    Boolean                @default(false)
  isAgeSpecific        Boolean                @default(false)
  sortOrder            Int                    @default(0)
  isActive             Boolean                @default(true)
  createdAt            DateTime               @default(now())
  updatedAt            DateTime
  CommunityActivityLog CommunityActivityLog[]
  CommunityPost        CommunityPost[]
}

model CommunityEvent {
  id              String    @id
  title           String
  description     String?
  venue           String?
  city            String?
  startDate       DateTime
  endDate         DateTime?
  imageUrl        String?
  isOnline        Boolean   @default(false)
  link            String?
  isAgeRestricted Boolean   @default(false)
  minAge          Int?
  maxAge          Int?
  attendeeCount   Int       @default(0)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime
}

model CommunityPost {
  id                  String              @id
  circleId            String
  authorId            String
  content             String
  status              PostStatus          @default(PENDING_AI)
  isPinned            Boolean             @default(false)
  isChallengeResponse Boolean             @default(false)
  challengeId         String?
  isFeatured          Boolean             @default(false)
  aiDecision          ModerationDecision?
  aiConfidence        Float?
  aiFlags             Json                @default("{}")
  crisisSeverity      CrisisSeverity      @default(NONE)
  humanReviewed       Boolean             @default(false)
  humanDecision       ModerationDecision?
  reviewedBy          String?
  reviewedAt          DateTime?
  reactionHeart       Int                 @default(0)
  reactionHug         Int                 @default(0)
  reactionBulb        Int                 @default(0)
  reactionFist        Int                 @default(0)
  replyCount          Int                 @default(0)
  createdAt           DateTime            @default(now())
  publishedAt         DateTime?
  updatedAt           DateTime
  deletedAt           DateTime?
  CommunityBookmark   CommunityBookmark[]
  User                User                @relation(fields: [authorId], references: [id])
  WeeklyChallenge     WeeklyChallenge?    @relation(fields: [challengeId], references: [id])
  CommunityCircle     CommunityCircle     @relation(fields: [circleId], references: [id])
  CommunityReply      CommunityReply[]

  @@index([circleId, publishedAt(sort: Desc)])
}

model CommunityReply {
  id                   String              @id
  postId               String
  parentReplyId        String?
  depth                Int                 @default(1)
  authorId             String
  content              String
  status               PostStatus          @default(PENDING_AI)
  aiDecision           ModerationDecision?
  crisisSeverity       CrisisSeverity      @default(NONE)
  humanReviewed        Boolean             @default(false)
  reactionHeart        Int                 @default(0)
  reactionHug          Int                 @default(0)
  createdAt            DateTime            @default(now())
  publishedAt          DateTime?
  deletedAt            DateTime?
  reactionBulb         Int                 @default(0)
  reactionFist         Int                 @default(0)
  CommunityBookmark    CommunityBookmark[]
  User                 User                @relation(fields: [authorId], references: [id])
  CommunityReply       CommunityReply?     @relation("CommunityReplyToCommunityReply", fields: [parentReplyId], references: [id])
  other_CommunityReply CommunityReply[]    @relation("CommunityReplyToCommunityReply")
  CommunityPost        CommunityPost       @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([postId, publishedAt])
}

model ModerationLog {
  id          String             @id
  contentId   String
  contentType String
  layer       String
  decision    ModerationDecision
  reasonCode  String?
  moderatorId String?
  createdAt   DateTime           @default(now())
  User        User?              @relation(fields: [moderatorId], references: [id])
}

model PeerLineMessage {
  id              String          @id
  sessionId       String
  senderRole      String
  content         String
  crisisFlag      Boolean         @default(false)
  sentAt          DateTime        @default(now())
  PeerLineSession PeerLineSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId, sentAt])
}

model PeerLineSession {
  id                                  String            @id
  menteeId                            String
  mentorId                            String?
  topicIds                            String[]
  status                              PeerLineStatus    @default(MATCHING)
  requestedVerified                   Boolean           @default(false)
  matchedAt                           DateTime?
  startedAt                           DateTime?
  endedAt                             DateTime?
  endReason                           String?
  menteeRating                        Int?
  mentorRating                        Int?
  hadCrisisFlag                       Boolean           @default(false)
  createdAt                           DateTime          @default(now())
  PeerLineMessage                     PeerLineMessage[]
  User_PeerLineSession_menteeIdToUser User              @relation("PeerLineSession_menteeIdToUser", fields: [menteeId], references: [id])
  User_PeerLineSession_mentorIdToUser User?             @relation("PeerLineSession_mentorIdToUser", fields: [mentorId], references: [id])
}

model PostReaction {
  id          String   @id
  contentId   String
  contentType String
  userId      String
  reaction    String
  createdAt   DateTime @default(now())
  User        User     @relation(fields: [userId], references: [id])

  @@unique([contentId, contentType, userId, reaction])
}

model WeeklyChallenge {
  id              String          @id
  theme           String
  description     String?
  startDate       DateTime
  endDate         DateTime
  promptsByCircle Json
  createdAt       DateTime        @default(now())
  CommunityPost   CommunityPost[]
}

enum UserRole {
  TEEN
  PARENT
  GUARDIAN
  EXPERT
}

enum ContentTier {
  JUNIOR
  TEEN_EARLY
  TEEN_LATE
  ADULT
}

enum AccountStatus {
  PENDING_SETUP
  PENDING_CONSENT
  ACTIVE_MINOR
  ACTIVE
  SUSPENDED
  DELETED
}

enum TrackerMode {
  active
  watching_waiting
  irregular_support
}

enum PeriodContentTone {
  GENTLE
  MODERATE
  DIRECT
}

enum ConsentRequestStatus {
  PENDING
  APPROVED
  EXPIRED
}

enum ChatSender {
  USER
  GIGI
  MODERATOR
}

enum EscalationLevel {
  LEVEL_0
  LEVEL_1
  LEVEL_2
  LEVEL_3
  LEVEL_4
}

enum CrisisSeverity {
  NONE
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum ModerationDecision {
  APPROVE
  HOLD
  REMOVE
  ESCALATE
}

enum PeerLineStatus {
  MATCHING
  QUEUED
  ACTIVE
  PAUSED
  COMPLETED
  CANCELLED
}

enum PostStatus {
  PENDING_AI
  PENDING_HUMAN
  APPROVED
  REMOVED
  AUTHOR_DELETED
}
