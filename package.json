{
  "name": "infano-care-api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "dotenv --override -e .env.development -e .env.local -- tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "lint": "eslint .",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:studio": "prisma studio",
    "delete-all-users": "dotenv -e .env.development -e .env.local -- tsx prisma/delete-all-users.ts",
    "create-test-user": "dotenv -e .env.development -e .env.local -- tsx prisma/create-test-user.ts",
    "reset-test-user": "dotenv -e .env.development -e .env.local -- tsx prisma/reset-test-user.ts",
    "delete-test-user": "dotenv -e .env.development -e .env.local -- tsx prisma/delete-test-user.ts"
  },
  "dependencies": {
    "@prisma/client": "^6.4.1",
    "@types/nodemailer": "^7.0.11",
    "bcryptjs": "^3.0.3",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "express": "^5.1.0",
    "express-rate-limit": "^8.1.0",
    "firebase-admin": "^13.7.0",
    "helmet": "^8.1.0",
    "ioredis": "^5.10.0",
    "jsonwebtoken": "^9.0.3",
    "node-cron": "^4.2.1",
    "nodemailer": "^8.0.3",
    "pg": "^8.16.3",
    "pino": "^9.9.0",
    "pino-gelf": "^3.0.0",
    "pino-http": "^10.5.0",
    "socket.io": "^4.8.3",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/compression": "^1.7.8",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.3",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^24.12.0",
    "@types/node-cron": "^3.0.11",
    "@types/pg": "^8.15.5",
    "@types/socket.io": "^3.0.1",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.8",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "dotenv-cli": "^8.0.0",
    "eslint": "^9.34.0",
    "globals": "^15.9.0",
    "pino-pretty": "^13.1.3",
    "prisma": "^6.4.1",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2",
    "typescript-eslint": "^8.0.0"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}
