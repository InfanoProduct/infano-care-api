# Server Configuration
NODE_ENV=development
PORT=4000
DATABASE_URL=postgresql://postgres:user@localhost:5432/infano?schema=public

# Networking & Security
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
PG_SSL=false
LOG_LEVEL=info

# External Services
GRAYLOG_HOST=localhost
GRAYLOG_PORT=12201

# SMS Configuration (Optional)
SMS_PROVIDER=mock
TWOFACTOR_API_KEY=
MSG91_AUTH_KEY=
MSG91_TEMPLATE_ID=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# AI Period Tracker Encryption Key (64-character hex)
CRYPTO_KEY=
GROQ_API_KEY=your_groq_api_key_here
